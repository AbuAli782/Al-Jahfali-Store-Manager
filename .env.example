# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in your host environment (Railway, Render, etc.).
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Optional, useful for callbacks or self-referential web links.
APP_URL="YOUR_APP_URL"

# PORT: Optional override for the runtime port. Railway provides this automatically.
PORT="3000"
